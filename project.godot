config_version=5

[application]

config/name="BulletJamVII"
config/version="0.0.1"
run/main_scene="uid://b11tac7gh5078"
config/features=PackedStringArray("4.6", "GL Compatibility")

[autoload]

LoadManager="*uid://caq2oowq6eg36"
GameManager="*uid://dsmbhfbht3sgo"
Events="*uid://dxagnueqq0sr6"
AudioManager="*uid://baqxn432oxoqc"
VFX="*uid://dmnsl7o60ype3"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

